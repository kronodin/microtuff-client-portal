# JWT secret — generate a strong random string in production
JWT_SECRET=change-me-to-a-long-random-secret-string
# Where uploaded files live (relative to project root). Outside public/ for security.
UPLOAD_DIR=./uploads
# Max sizes (bytes). Configurable.
MAX_DOC_IMAGE_BYTES=10485760
MAX_VIDEO_BYTES=104857600
# Admin phone (must match a seeded user). Grants access to /admin
ADMIN_PHONE=+15551234567
